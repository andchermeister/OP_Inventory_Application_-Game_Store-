<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>
  <body>
    <h1>Games page</h1>
    <ul class="game-list-item">
        <% games.forEach(game => { %>
        <li>
          <p>Title: <%= game.title %></p>
          <p>Genre: <%= game.genre_name %></p>
          <p>Developer: <%= game.company_name %></p>
          <p>Release date: <%= new Date(game.release_date).toLocaleDateString() %></p>
          <p>Rating: <%= game.rating %></p>
          <button>Delete game</button>
        </li>
        <% });  %>  
    </ul>
    <a href="/newgame"><button>Add new game</button></a>
    <a href="/"><button>Go back home</button></a>
  </body>
</html>
